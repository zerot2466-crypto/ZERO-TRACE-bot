# ╔══════════════════════════════════════════════════════════════════════╗
# ║           ZERO TRACE BOT v5.0 — Configuration complète             ║
# ║  Copie ce fichier en .env et remplis les valeurs manquantes        ║
# ║  Les clés marquées ✅ REQUIS sont obligatoires pour démarrer       ║
# ║  Les clés marquées 🔶 OPTIONNEL améliorent certaines fonctions     ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 1. CONFIGURATION PRINCIPALE
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ✅ REQUIS — Ton numéro WhatsApp (indicatif pays + numéro, sans + ni espaces)
# Exemple Zambie : 260951829244 | Maroc : 212612345678 | France : 33612345678
OWNER_NUMBER=260951829244

# ✅ REQUIS — Numéro du compte bot (le compte WhatsApp qui sera le bot)
PAIRING_NUMBER=260000000000

# 🔶 OPTIONNEL — Préfixe des commandes (défaut: .)
# Tu peux le changer en live avec .setprefix
PREFIX=.

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 2. SERVEUR DE PAIRING (page web de connexion)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 🔶 OPTIONNEL — Port du serveur web (défaut: 3000)
PAIR_PORT=3000

# 🔶 OPTIONNEL — URL publique du bot pour la page de pairing
# - Si tu héberges sur Render/Railway : https://ton-bot.onrender.com
# - Si en local : laisser vide (localtunnel démarre automatiquement)
PAIR_HOST=

# 🔶 OPTIONNEL — Domaine Netlify de ta page pair.html (pour CORS)
PAIR_ALLOWED_ORIGIN=https://zerotracepair.netlify.app

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 3. APIs INTELLIGENCE ARTIFICIELLE (chatbot .ai, .agent, .chatbot)
#    Le bot essaie les providers dans l'ordre — au moins 1 est requis
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ✅ REQUIS (au moins 1) — OpenRouter — Provider principal
# Comment l'obtenir :
#   1. Va sur https://openrouter.ai
#   2. Crée un compte → clique sur "Keys" → "Create Key"
#   3. Copie la clé qui commence par sk-or-...
#   Modèles gratuits disponibles : deepseek/deepseek-chat-v3-0324:free
OPENROUTER_API_KEY=sk-or-

# ✅ REQUIS (au moins 1) — Groq — Très rapide, gratuit, aussi pour le vocal STT
# Comment l'obtenir :
#   1. Va sur https://console.groq.com
#   2. Crée un compte → "API Keys" → "Create API Key"
#   3. Copie la clé qui commence par gsk_...
GROQ_API_KEY=gsk_

# 🔶 OPTIONNEL — Cerebras — IA ultra-rapide (fallback)
# Comment l'obtenir :
#   1. Va sur https://cloud.cerebras.ai
#   2. Crée un compte → "API Keys" → "Generate"
CEREBRAS_API_KEY=

# 🔶 OPTIONNEL — Together AI — Accès à des centaines de modèles open-source
# Comment l'obtenir :
#   1. Va sur https://api.together.xyz
#   2. Crée un compte → "Settings" → "API Keys" → "Generate API Key"
#   Crédit gratuit de départ : 1$ offert
TOGETHER_API_KEY=

# 🔶 OPTIONNEL — Mistral AI — IA française, excellente en français
# Comment l'obtenir :
#   1. Va sur https://console.mistral.ai
#   2. Crée un compte → "API Keys" → "Create new key"
#   Tier gratuit disponible (expérimental)
MISTRAL_API_KEY=

# 🔶 OPTIONNEL — Google Gemini — Vision + texte, très puissant
# Comment l'obtenir :
#   1. Va sur https://aistudio.google.com/app/apikey
#   2. Connecte-toi avec Google → "Create API key"
#   Totalement gratuit avec limites généreuses
GEMINI_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 4. APIs VOCAL / TTS (commandes .tts, .clonevoix, transcription auto)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 🔶 OPTIONNEL — ElevenLabs — TTS haute qualité + clonage de voix
# Comment l'obtenir :
#   1. Va sur https://elevenlabs.io
#   2. Crée un compte → clique sur ton avatar → "Profile + API key"
#   3. Copie la clé qui commence par sk_...
#   Tier gratuit : 10 000 caractères/mois
ELEVENLABS_API_KEY=sk_

# 🔶 OPTIONNEL — VoiceRSS — TTS alternatif léger (fallback)
# Comment l'obtenir :
#   1. Va sur https://voicerss.org/api
#   2. Crée un compte → "Get API Key"
#   Gratuit jusqu'à 350 requêtes/jour
VOICERSS_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 5. APIs RECHERCHE & MÉDIAS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 🔶 OPTIONNEL — Google Custom Search — Recherche d'images (.imgsearch)
# Comment l'obtenir :
#   1. Va sur https://console.cloud.google.com
#   2. Crée un projet → active "Custom Search API"
#   3. "Credentials" → "Create API Key" → copie la clé AIza...
#   4. Va sur https://programmablesearchengine.google.com → crée un moteur
#   5. Récupère le CX (identifiant du moteur de recherche)
#   Gratuit : 100 requêtes/jour
GOOGLE_CSE_KEY=AIza
GOOGLE_CSE_CX=

# 🔶 OPTIONNEL — GNews — Actualités (.news)
# Comment l'obtenir :
#   1. Va sur https://gnews.io
#   2. Crée un compte → "Dashboard" → "API Key"
#   Gratuit : 100 requêtes/jour
GNEWS_API_KEY=

# 🔶 OPTIONNEL — NASA — Images et données spatiales (.nasa)
# Comment l'obtenir :
#   1. Va sur https://api.nasa.gov
#   2. Remplis le formulaire → reçois la clé par email
#   Gratuit sans limite raisonnable
NASA_API_KEY=DEMO_KEY

# 🔶 OPTIONNEL — Giphy — GIFs animés
# Comment l'obtenir :
#   1. Va sur https://developers.giphy.com
#   2. Crée un compte → "Create an App" → API → copie la clé
#   Gratuit
GIPHY_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 6. APIs SÉCURITÉ / OSINT (commandes .scanlink, .pwned, .cvesearch)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 🔶 OPTIONNEL — VirusTotal — Analyse de liens et fichiers (.scanlink)
# Comment l'obtenir :
#   1. Va sur https://www.virustotal.com
#   2. Crée un compte → clique sur ton avatar → "API Key"
#   Gratuit : 4 requêtes/minute, 500/jour
VIRUSTOTAL_API_KEY=

# 🔶 OPTIONNEL — URLScan.io — Analyse de sites web
# Comment l'obtenir :
#   1. Va sur https://urlscan.io
#   2. Crée un compte → "Settings" → "API Key"
#   Gratuit avec limites
URLSCAN_API_KEY=

# 🔶 OPTIONNEL — HaveIBeenPwned — Vérification de fuites (.pwned email)
# Comment l'obtenir :
#   1. Va sur https://haveibeenpwned.com/API/Key
#   2. Paye 3.50$/mois pour l'API email (la vérif password est gratuite)
#   Note : la vérification de MOT DE PASSE est gratuite sans clé
HIBP_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 7. APIs IMAGE & VIDÉO (.imagine, .sora, .vision)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 🔶 OPTIONNEL — Remove.bg — Suppression de fond d'image
# Comment l'obtenir :
#   1. Va sur https://www.remove.bg/api
#   2. Crée un compte → "API" → "Get API Key"
#   Gratuit : 50 images/mois
REMOVEBG_API_KEY=

# 🔶 OPTIONNEL — URL de l'API de génération d'images custom
# Défaut : Pollinations AI (gratuit, sans clé)
IMAGE_API_URL=https://image.pollinations.ai/prompt/

# 🔶 OPTIONNEL — URL et clé de l'API de génération de vidéos (.sora)
VIDEO_API_URL=
VIDEO_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 8. CONFIGURATION MENU & LIENS PUBLICS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 🔶 OPTIONNEL — GIF/vidéo affiché dans le carousel du menu
MENU_GIF_URL=

# 🔶 OPTIONNEL — Lien de ton canal WhatsApp
CHANNEL_LINK=https://whatsapp.com/channel/TON_CANAL

# 🔶 OPTIONNEL — Lien GitHub du projet
GITHUB_LINK=https://github.com/zero-trace/bot

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 9. ANTI-SPAM (rate limiting des commandes)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 🔶 OPTIONNEL — Activer le rate limit (true/false)
RATELIMIT_ENABLED=true

# 🔶 OPTIONNEL — Max commandes par fenêtre de temps
RATELIMIT_MAX=5

# 🔶 OPTIONNEL — Durée fenêtre en millisecondes (20000 = 20 secondes)
RATELIMIT_WINDOW_MS=20000
